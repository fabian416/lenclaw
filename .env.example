# =============================================================================
# Lenclaw - Environment Variables
# Copy this file to .env and fill in production values
# Usage: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Application environment: local, staging, production
APP_ENV=local
# Enable debug mode (disable in production)
DEBUG=true

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
# Host and port for the backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lenclaw_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full connection string (constructed from above, or override directly)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/lenclaw_db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# CHANGE THIS IN PRODUCTION - use: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
NONCE_EXPIRE_MINUTES=10

# -----------------------------------------------------------------------------
# Web3 / Blockchain
# -----------------------------------------------------------------------------
# Base mainnet RPC endpoint
WEB3_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Block explorer API keys (for contract verification)
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# RPC endpoints for multi-chain
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# -----------------------------------------------------------------------------
# Caddy / Domain
# -----------------------------------------------------------------------------
# Production domain for Caddy HTTPS
DOMAIN=localhost

# -----------------------------------------------------------------------------
# Docker / Registry
# -----------------------------------------------------------------------------
# Container registry for CI/CD image pushes
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/lenclaw

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

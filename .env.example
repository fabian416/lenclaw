# =============================================================================
# Lenclaw - Environment Variables
# Copy this file to .env and fill in production values
# Usage: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=local
DEBUG=true

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lenclaw_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/lenclaw_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# CHANGE THIS IN PRODUCTION - use: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Web3 / Blockchain
# -----------------------------------------------------------------------------
WEB3_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
BASESCAN_API_KEY=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,https://lenclaw.xyz

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# WDK Agent Configuration
# Copy this file to .env and fill in your values

# WDK seed phrase (24 words). Leave empty to auto-generate on first run.
# WARNING: Back this up securely. Losing it means losing access to the wallet.
WDK_SEED_PHRASE=

# Base RPC URL (default: public Base mainnet RPC)
BASE_RPC_URL=https://mainnet.base.org

# Lenclaw contract addresses on Base
AGENT_REGISTRY_ADDRESS=
REVENUE_LOCKBOX_ADDRESS=
AGENT_VAULT_ADDRESS=
AGENT_CREDIT_LINE_ADDRESS=

# Agent identity
AGENT_ID=

# Revenue monitoring interval in milliseconds (default: 30000 = 30 seconds)
POLL_INTERVAL_MS=30000

# Minimum USDC balance to trigger revenue processing (in USDC units, e.g. 1.0 = 1 USDC)
MIN_REVENUE_THRESHOLD=1.0

# Log level: debug | info | warn | error
LOG_LEVEL=info
